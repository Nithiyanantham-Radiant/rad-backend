  Day             DateTime @db.Date
  Department      String
  Half            String
  /// Multiple data types found: Float: 96.9%, Int: 3.1% out of 65 sampled entries
  Margin_LLY      Json
  /// Multiple data types found: Float: 96.9%, Int: 3.1% out of 65 sampled entries
  Margin_LY       Json
  Month           String
  /// Multiple data types found: Float: 96.9%, Int: 3.1% out of 65 sampled entries
  Planned_Margin  Json
  /// Multiple data types found: Float: 96.9%, Int: 3.1% out of 65 sampled entries
  Planned_Sales   Json
  Quarter         String
  Ranges          String
  /// Multiple data types found: Float: 96.9%, Int: 3.1% out of 65 sampled entries
  Sales_LLY       Json
  /// Multiple data types found: Float: 96.9%, Int: 3.1% out of 65 sampled entries
  Sales_LY        Json
  Week            String
