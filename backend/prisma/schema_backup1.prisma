generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

type DatasetsFields {
  name     String
  required Boolean
  type     String
}

type FormsMapping {
  mappings       FormsMappingMappings[]
  /// Could not determine type: the field only had null or empty values in the sample set.
  unmappedFields Json?
}

type FormsMappingMappings {
  datasetKey String
  formKey    String
  /// Could not determine type: the field only had null or empty values in the sample set.
  transform  Json?
}

type FormsSchema {
  properties FormsSchemaProperties
  type       String
}

type FormsSchemaProperties {
  Department       FormsSchemaPropertiesDepartment?
  datePicker       FormsSchemaPropertiesDatePicker?
  dateRange        FormsSchemaPropertiesDateRange?
  dateTimePicker   FormsSchemaPropertiesDateTimePicker?
  dropdown         FormsSchemaPropertiesDropdown?
  multipleDropdown FormsSchemaPropertiesMultipleDropdown?
  numberField      FormsSchemaPropertiesNumberField?
  textField        FormsSchemaPropertiesTextField?
}

type FormsSchemaPropertiesDatePicker {
  format String
  title  String
  type   String
}

type FormsSchemaPropertiesDateRange {
  properties FormsSchemaPropertiesDateRangeProperties
  required   String[]
  title      String
  type       String
}

type FormsSchemaPropertiesDateRangeProperties {
  from FormsSchemaPropertiesDateRangePropertiesFrom
  to   FormsSchemaPropertiesDateRangePropertiesTo
}

type FormsSchemaPropertiesDateRangePropertiesFrom {
  format String
  type   String
}

type FormsSchemaPropertiesDateRangePropertiesTo {
  format String
  type   String
}

type FormsSchemaPropertiesDateTimePicker {
  format String
  title  String
  type   String
}

type FormsSchemaPropertiesDepartment {
  enum  String[]
  title String
  type  String
}

type FormsSchemaPropertiesDropdown {
  enum  String[]
  title String
  type  String
}

type FormsSchemaPropertiesMultipleDropdown {
  items       FormsSchemaPropertiesMultipleDropdownItems
  title       String
  type        String
  uniqueItems Boolean
}

type FormsSchemaPropertiesMultipleDropdownItems {
  enum String[]
  type String
}

type FormsSchemaPropertiesNumberField {
  multipleOf Int
  title      String
  type       String
}

type FormsSchemaPropertiesTextField {
  title String
  type  String
}

type FormsUiSchema {
  Department       FormsUiSchemaDepartment?
  dateRange        FormsUiSchemaDateRange?
  dropdown         FormsUiSchemaDropdown?
  multipleDropdown FormsUiSchemaMultipleDropdown?
  /// Nested objects had no data in the sample dataset to introspect a nested type.
  textField        Json?
  ui_order         String[]                       @map("ui:order")
}

type FormsUiSchemaDateRange {
  ui_widget String @map("ui:widget")
}

type FormsUiSchemaDepartment {
  ui_widget String @map("ui:widget")
}

type FormsUiSchemaDropdown {
  ui_widget String @map("ui:widget")
}

type FormsUiSchemaMultipleDropdown {
  classNames String
  ui_options FormsUiSchemaMultipleDropdownUiOptions @map("ui:options")
  ui_widget  String @map("ui:widget")
}

type FormsUiSchemaMultipleDropdownUiOptions {
multiple Boolean
}

type MfpPlanItem {
  BusinessUnit String
  Department   String
}

type MfpPlanLocation {
  /// Could not determine type: the field only had null or empty values in the sample set.
  LOCATION_TYPE Json?
  /// Could not determine type: the field only had null or empty values in the sample set.
  country       Json?
  /// Could not determine type: the field only had null or empty values in the sample set.
  state         Json?
}

type MfpPlanTime {
  Day     DateTime @db.Date
  Half    String
  Month   String
  Quarter String
  Week    String
  Year    Int
}

model datasets {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime         @db.Date
  datasetId String
  fields    DatasetsFields[]
  name      String
  updatedAt DateTime         @db.Date
}

model fact_data {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  Day          DateTime @db.Date
  Margin       Int
  Ranges       String
  Sales        Int
  Year         Int
  gross_profit Int
  gross_sales  Int
  net_sales    Int
}

model forms {
  id         String        @id @default(auto()) @map("_id") @db.ObjectId
  craftState String
  createdAt  DateTime      @db.Date
  datasetId  String
  mapping    FormsMapping
  name       String
  schema     FormsSchema
  uiSchema   FormsUiSchema
  updatedAt  DateTime      @db.Date
  useCase    String
}

model item {
  id           String @id @default(auto()) @map("_id") @db.ObjectId
  BusinessUnit String
  Department   String
  Ranges       String
}

/// This collection uses a JSON Schema defined in the database, which requires additional setup for migrations. Visit https://pris.ly/d/mongodb-json-schema for more info.
model location {
  id                  String   @id @map("_id")
  city                String
  country             String
  created_at          DateTime @db.Date
  district            String
  effective_from_date DateTime @db.Date
  /// Could not determine type: the field only had null or empty values in the sample set.
  effective_to_date   Json?
  locality            String
  postal_area         String
  region              String
  state               String
  timezone            String
  updated_at          DateTime @db.Date
}

