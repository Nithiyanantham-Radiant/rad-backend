model product_inventory {
  id           String @id @map("_id")
  category     String
  price        Int
  product_name String
  stock        Int
}

model rupesh_Fact {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  Item          String[]
  ItemId        BigInt
  Location      String[]
  LocationId    BigInt
  Planned_Sales Int
  Planning_Type String
  Sales_lY      Int
  Sales_lYY     Int
  Time          String[]
  TimeId        BigInt
  created_at    DateTime @db.Date

  @@index([Planning_Type], map: "Planning_Type_1")
  @@index([LocationId], map: "LocationId_1")
  @@index([ItemId], map: "ItemId_1")
  @@index([TimeId], map: "TimeId_1")
}

model submissions {
  id String @id @default(auto()) @map("_id") @db.ObjectId
}

model time {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  All_Time String
  Day      DateTime @db.Date
  Half     String
  Month    String
  Quarter  String
  Week     String
  Year     Int
}
