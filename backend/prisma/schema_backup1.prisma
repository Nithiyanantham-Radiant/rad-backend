/// This collection uses a JSON Schema defined in the database, which requires additional setup for migrations. Visit https://pris.ly/d/mongodb-json-schema for more info.
model mfp_td_plan {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  Approved_Margin Float
  Approved_Sales  Float
  BusinessUnit    String
  Day             DateTime @db.Date
  Department      String
  Half            String
  Margin_LLY      Float
  Margin_LY       Float
  Month           String
  Planned_Margin  Float
  Planned_Sales   Float
  Quarter         String
  Ranges          String
  Sales_LLY       Float
  Sales_LY        Float
  Week            String
